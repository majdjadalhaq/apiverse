# Copy to `.env.local` for local dev, or set these in the Vercel project
# dashboard for previews/production. Never commit the real values.

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable (anon) key. Safe to ship to the browser; all row
# access is still gated by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role / secret key. Server-only. Used by scripts that
# need to bypass RLS (e.g. seeding). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
